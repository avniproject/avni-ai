def test_max_retries_exhausted():
    """After 3 failed cycles, flow gives up gracefully."""
    flow = AppConfiguratorFlow.from_env()
    flow.entities = load_hopelessly_broken_entities()
    flow.max_cycles = 3
    result = flow.run()
    assert flow.cycle_count == 3
