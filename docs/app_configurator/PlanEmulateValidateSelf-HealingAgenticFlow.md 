        self.entities = {}
        self.spec_yaml = ""
        self.bundle_zip_b64 = ""
        self.existing_bundle_b64 = ""
        self.upload_task_id = ""
        self.cycle_count = 0
        self.max_cycles = 3
        self.error_diagnosis = ""
