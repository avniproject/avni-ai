# Avni Core Configuration
AVNI_BASE_URL=https://app.avniproject.org
AVNI_AI_SERVER_URL=https://app-ai.avniproject.org
AVNI_CLIENT_TIMEOUT_SECONDS=60

# Store TTL and response size limits
ENTITY_STORE_TTL_HOURS=6
BUNDLE_STORE_TTL_HOURS=6
SPEC_STORE_TTL_HOURS=6
MAX_SPEC_RESPONSE_CHARS=8000

# OpenAI Configuration (required for LLM evaluation)
OPENAI_API_KEY=your_openai_api_key_here

# Dify Core Configuration
DIFY_API_BASE_URL=https://api.dify.ai/v1

# Judge Framework Dify API Keys
# Primary conversation testing workflow
DIFY_API_KEY=your_dify_production_api_key_here

# Production form validation testing workflow
DIFY_FORM_VALIDATION_API_KEY=your_dify_form_validation_production_api_key_here

# Production visit scheduling rules testing workflow
DIFY_SCHEDULING_API_KEY=your_dify_scheduling_production_api_key_here

# Additional specialized workflows (for future extensions)
DIFY_ADVANCED_CONVERSATION_API_KEY=your_dify_advanced_conversation_production_api_key_here
DIFY_MULTI_LANGUAGE_API_KEY=your_dify_multi_language_production_api_key_here

# Judge Framework Configuration
JUDGE_FRAMEWORK_DEFAULT_MODEL=gpt-4o
JUDGE_FRAMEWORK_DEFAULT_TEMPERATURE=0.1
JUDGE_FRAMEWORK_MAX_ITERATIONS=8
JUDGE_FRAMEWORK_TIMEOUT_SECONDS=120